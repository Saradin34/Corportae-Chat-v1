# ===== Corporate Chat — environment =====
# Copy to .env and adjust as needed (setup.py does this automatically).

# Public HTTP port (the app will be available at http://localhost:<HTTP_PORT>)
HTTP_PORT=80

# PostgreSQL
POSTGRES_USER=chat
POSTGRES_PASSWORD=chatpass
POSTGRES_DB=corporate_chat

# Security — CHANGE THIS to a long random string in production
SECRET_KEY=please-change-this-to-a-long-random-secret-string-123456

# Default administrator (auto-created on first start)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@corporate.chat
ADMIN_PASSWORD=Admin12345!

# Debug mode (true enables /api/docs verbose logging)
DEBUG=false

# ===== Authentication mode =====
# ALLOW_LOCAL_AUTH=false  -> "AD only" (local registration/login disabled)
ALLOW_LOCAL_AUTH=true

# ===== Active Directory / LDAP (on-prem) =====
# Enable AD sign-in:
LDAP_ENABLED=true
# One or more domain controllers (comma-separated). Use ldaps:// for SSL.
LDAP_SERVERS=ldap://forseti.kupava.by:389
# Use LDAPS (port 636). If false you can use StartTLS instead.
LDAP_USE_SSL=false
LDAP_START_TLS=false
# Base DN where user accounts live
LDAP_BASE_DN=OU=MAZ-Kupava,DC=kupava,DC=by
# UPN suffix for the bind (user@domain). Usually your AD DNS domain.
LDAP_DOMAIN=kupava.by
# Optional down-level (NetBIOS) name for DOMAIN\user bind fallback
LDAP_NETBIOS=KUPAVA
# Login attribute (AD = sAMAccountName)
LDAP_LOGIN_ATTR=sAMAccountName
# Optional service account to read profiles/groups (recommended).
# Leave empty to search with the signed-in user's own credentials.
LDAP_BIND_DN=CN=testopenfire,OU=Services,OU=Users,OU=MAZ-Kupava,DC=kupava,DC=by
LDAP_BIND_PASSWORD=123qweASD
# AD group (full DN) whose members become APP ADMINS:
LDAP_ADMIN_GROUP=CN=ASU-Admin,OU=Roles,OU=Groups,OU=MAZ-Kupava,DC=kupava,DC=by
# Optional AD group (full DN) REQUIRED to sign in (allow-list). Empty = anyone in AD.
LDAP_REQUIRED_GROUP=CN=APP_TrueConf,OU=APP,OU=Groups,OU=MAZ-Kupava,DC=kupava,DC=by
LDAP_TIMEOUT=8
# Mirror AD groups/OU as group chats on login (TrueConf-style address book)
LDAP_SYNC_GROUPS=true
# Only mirror groups whose DN contains one of these substrings (empty = all)
LDAP_GROUP_FILTER=
# Skip these builtin AD groups
LDAP_GROUP_EXCLUDE=Domain Users,Domain Computers,Domain Guests

# ===== SSO (NTLM / Kerberos / Reverse Proxy) =====
# Enable SSO (single sign-on) via SPNEGO (Negotiate) or reverse-proxy headers.
# SSO_ENABLED=true will expose the /api/auth/sso endpoint.
SSO_ENABLED=true
# Trust REMOTE_USER / X-Remote-User headers from a reverse proxy (nginx/IIS/Apache).
SSO_ALLOW_PROXY=true
# Allow direct SPNEGO handshake between browser and backend (requires keytab on Linux).
SSO_ALLOW_NEGOTIATE=true
# Kerberos SPN / hostname used in the keytab (e.g. HTTP/chat.company.local@COMPANY.LOCAL).
SSO_SERVICE_NAME=HTTP/chat.kupava.by@KUPAVA.BY
# Absolute path to the Kerberos keytab inside the backend container.
# Mount it via docker-compose volumes: /etc/krb5.keytab:/etc/krb5.keytab:ro
SSO_KEYTAB_PATH=/etc/krb5.keytab

# ----- Typical "AD only" production setup -----
#   ALLOW_LOCAL_AUTH=false
#   LDAP_ENABLED=true
#   LDAP_SERVERS=ldaps://dc1.company.local:636,ldaps://dc2.company.local:636
#   LDAP_USE_SSL=true
#   LDAP_BASE_DN=DC=company,DC=local
#   LDAP_DOMAIN=company.local
#   LDAP_NETBIOS=COMPANY
#   LDAP_ADMIN_GROUP=CN=ChatAdmins,OU=Groups,DC=company,DC=local
