# ============================================================
#  Corporate Chat — ПРОДАКШЕН-конфиг для on-prem Active Directory
#  Скопируйте в .env и подставьте значения вашей организации.
#  cp .env.production.example .env
# ============================================================

# ---- Внешний порт (за nginx). 80 = HTTP, для HTTPS см. nginx ниже ----
HTTP_PORT=80

# ---- PostgreSQL (оставьте как есть или задайте свои) ----
POSTGRES_USER=chat
POSTGRES_PASSWORD=ЗАМЕНИТЕ_НА_ДЛИННЫЙ_ПАРОЛЬ
POSTGRES_DB=corporate_chat

# ---- Подпись JWT: ОБЯЗАТЕЛЬНО замените на случайную строку 48+ символов ----
# Сгенерировать: openssl rand -base64 48
SECRET_KEY=ЗАМЕНИТЕ_openssl_rand_base64_48

# ---- Аварийный локальный администратор (на случай недоступности AD) ----
# Этот аккаунт работает даже если AD упал. Держите пароль в секрете.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@company.local
ADMIN_PASSWORD=Admin12345!

# ============================================================
#  АУТЕНТИФИКАЦИЯ ЧЕРЕЗ ACTIVE DIRECTORY
# ============================================================
# Включить вход по доменным учётным записям:
LDAP_ENABLED=true

# Режим логина:
#   ALLOW_LOCAL_AUTH=true  -> можно входить и по AD, и локально (рекомендуется:
#                            остаётся аварийный admin)
#   ALLOW_LOCAL_AUTH=false -> ТОЛЬКО AD (локальная регистрация/вход отключены)
ALLOW_LOCAL_AUTH=true

# ---- Контроллеры домена ----
# Несколько DC через запятую для отказоустойчивости.
# РЕКОМЕНДУЕТСЯ LDAPS (порт 636) — пароли не идут открытым текстом.
LDAP_SERVERS=ldap://forseti.kupava.by:389   
LDAP_USE_SSL=false
LDAP_START_TLS=false

# Если LDAPS пока недоступен (нет сертификата на DC), можно временно так:
#   LDAP_SERVERS=ldap://dc1.company.local:389
#   LDAP_USE_SSL=false
# (НЕБЕЗОПАСНО для паролей вне доверенной сети — включите LDAPS как можно скорее.)

# ---- Параметры домена ----
# Base DN, где лежат учётные записи (обычно корень домена):
LDAP_BASE_DN=OU=MAZ-Kupava,DC=kupava,DC=by
# DNS-имя домена (для входа вида user@company.local):
LDAP_DOMAIN=kupava.by
# NetBIOS-имя (для входа вида COMPANY\user). Узнать: echo %USERDOMAIN%
LDAP_NETBIOS=KUPAVA
# Атрибут логина в AD (для AD всегда sAMAccountName):
LDAP_LOGIN_ATTR=sAMAccountName

# ---- Сервисная учётка для чтения каталога (РЕКОМЕНДУЕТСЯ) ----
# Обычный доменный пользователь (можно без особых прав) для поиска
# профилей и групп. Можно оставить пустым — тогда поиск идёт от имени
# самого вошедшего пользователя.
LDAP_BIND_DN=CN=testopenfire,OU=Services,OU=Users,OU=MAZ-Kupava,DC=kupava,DC=by
LDAP_BIND_PASSWORD=123qweASD

# ---- Маппинг ролей и доступа ----
# Полный DN группы, члены которой становятся АДМИНАМИ приложения:
LDAP_ADMIN_GROUP=CN=ASU-Admin,OU=Roles,OU=Groups,OU=MAZ-Kupava,DC=kupava,DC=by
# (опц.) Только члены этой группы вообще могут войти (allow-list).
# Пусто = вход разрешён любому пользователю домена.
LDAP_REQUIRED_GROUP=CN=APP_TrueConf,OU=APP,OU=Groups,OU=MAZ-Kupava,DC=kupava,DC=by
LDAP_TIMEOUT=8

# ---- Синхронизация групп AD -> групповые чаты приложения ----
LDAP_SYNC_GROUPS=true
# Зеркалить только группы, чей DN содержит подстроку (пусто = все memberOf):
#LDAP_GROUP_FILTER=OU=Departments
LDAP_GROUP_FILTER=(&(|(objectclass=group))(description=*)(!(cn=ACL_*))(!(cn=INT_*))(!(cn=GPO_*))(&(cn=*-*)))
# Игнорировать встроенные группы:
LDAP_GROUP_EXCLUDE=Domain Users,Domain Computers,Domain Guests

# ============================================================
#  SSO (NTLM / Kerberos / Reverse-Proxy)
# ============================================================
# Включить единый вход (SSO) через SPNEGO / Negotiate или заголовки прокси:
SSO_ENABLED=true
# Доверять заголовкам REMOTE_USER / X-Remote-User от reverse proxy (nginx/IIS/Apache):
SSO_ALLOW_PROXY=true
# Разрешить прямой SPNEGO-хендшейк между браузером и бэкендом (требует keytab на Linux):
SSO_ALLOW_NEGOTIATE=true
# Kerberos SPN / hostname из keytab (например HTTP/chat.company.local@COMPANY.LOCAL):
SSO_SERVICE_NAME=HTTP/chat.kupava.by@KUPAVA.BY
# Путь к keytab внутри контейнера бэкенда. Примонтируйте через volumes:
#   /etc/krb5.keytab:/etc/krb5.keytab:ro
SSO_KEYTAB_PATH=/etc/krb5.keytab

DEBUG=false

# ---- CORS (безопасность) ----
# Фронтенд и API на одном домене (через nginx), поэтому CORS не нужен —
# оставьте пустым. Заполняйте ТОЛЬКО если фронт на другом домене.
# Пример: CORS_ORIGINS=https://chat.company.local
CORS_ORIGINS=
AMI_ENABLED=true
AMI_HOST=192.168.30.1
AMI_PORT=5038
AMI_USERNAME=y00juTfa
AMI_SECRET='Asahi$zeD123'
AMI_RECONNECT_SECONDS=5